# Python virtual environment — recreate with: pip install -r requirements.txt
venv/

# Python compiled bytecode — auto-generated, never commit
__pycache__/
*.pyc
*.pyo

# Environment variables — contains secrets (API keys, passwords)
.env

# Tool caches — auto-generated by mypy, ruff, pytest
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Test coverage reports
htmlcov/

# Build artifacts
*.egg-info/
dist/
build/

# Dashboard (React) — recreate with: npm install
dashboard/node_modules/
dashboard/dist/

# Load test HTML reports — generated, not source code
docs/load_test_results/*.html

githistory.txt